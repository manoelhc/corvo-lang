# dns_example.corvo - dns.resolve and dns.lookup
# NOTE: These examples require an active internet/DNS connection.

sys.echo("=== dns.resolve ===")
# Resolves a hostname to one or more IP addresses
@ips = dns.resolve("localhost")
sys.echo("IPs for localhost:")
browse(@ips, idx, ip) {
    sys.echo("  ${@ip}")
}

sys.echo("")
sys.echo("=== dns.lookup ===")
# Reverse DNS: looks up the hostname for an IP address
@hostname = dns.lookup("127.0.0.1")
sys.echo("Hostname for 127.0.0.1: ${@hostname}")
