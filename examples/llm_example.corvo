# llm_example.corvo - llm.model, llm.prompt, llm.embed, llm.chat
# NOTE: llm functions are placeholder implementations that return stub values.
#       Wire up a real provider to get live responses.

sys.echo("=== llm.model ===")
# Returns a "provider:model" identifier string
@model_id = llm.model("gpt-4o", "openai")
sys.echo("Model ID: ${@model_id}")

@local_model = llm.model("llama3", "ollama")
sys.echo("Local model: ${@local_model}")

sys.echo("")
sys.echo("=== llm.prompt ===")
# Sends a prompt to a model and returns the text response
@response = llm.prompt(@model_id, "What is the capital of France?")
sys.echo("Response: ${@response}")

sys.echo("")
sys.echo("=== llm.embed ===")
# Returns a list of numbers (embedding vector) for the given text
@embedding = llm.embed(@model_id, "Hello, world!")
sys.echo("Embedding dimensions: ${list.len(@embedding)}")
sys.echo("First value: ${list.get(@embedding, 0)}")

sys.echo("")
sys.echo("=== llm.chat ===")
# Multi-turn chat: provide a session ID, model, and list of message maps
@messages = [{"role": "user", "content": "Tell me a joke."}]
@reply = llm.chat("session-1", @model_id, @messages)
sys.echo("Role: ${map.get(@reply, "role")}")
sys.echo("Content: ${map.get(@reply, "content")}")
