sys.echo("")
sys.echo("=== notifications.os ===")
try {
    @os_result = notifications.os("Corvo", "Hello from Corvo!")
    sys.echo("OS notification sent: ${map.get(@os_result, "success")}")
} fallback {
    sys.echo("(skipped — no desktop notification support available)")
}

sys.echo("")
sys.echo("=== notifications.irc ===")
try {
    @irc_result = notifications.irc(
        "irc.libera.chat",
        6667,
        "corvo-bot",
        "#corvo-test",
        "Hello from Corvo!",
        ""
    )
    sys.echo("IRC sent: ${map.get(@irc_result, "success")}")
} fallback {
    sys.echo("(skipped — no IRC server reachable)")
}
