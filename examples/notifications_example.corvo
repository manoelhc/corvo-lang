sys.echo("")
sys.echo("=== notifications.discord ===")
try {
    @discord_result = notifications.discord(
        "https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN",
        "Hello from Corvo!"
    )
    sys.echo("Discord status: ${map.get(@discord_result, "status_code")}")
