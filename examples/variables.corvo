# variables.corvo - Working with variables
@x = 10
@y = 20
@sum = math.add(@x, @y)
sys.echo("${@x} + ${@y} = ${@sum}")

@product = math.mul(@x, @y)
sys.echo("${@x} * ${@y} = ${@product}")

@ratio = math.div(@y, @x)
sys.echo("${@y} / ${@x} = ${@ratio}")

# String operations
@greeting = string.concat("Hello, ", "World")
sys.echo(@greeting)
sys.echo("Uppercase: ${string.to_upper(@greeting)}")
sys.echo("Length: ${string.len(@greeting)}")
