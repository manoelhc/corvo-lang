sys.echo("")
sys.echo("=== notifications.teams ===")
try {
    @teams_result = notifications.teams(
        "https://outlook.office.com/webhook/YOUR_WEBHOOK_URL",
        "Hello from Corvo!"
    )
    sys.echo("Teams status: ${map.get(@teams_result, "status_code")}")
