# notifications_example.corvo — notifications.*
# NOTE: All examples require valid credentials and network access.
#       Each call is wrapped in try/fallback so the file runs cleanly offline
#       or without real credentials.

sys.echo("=== notifications.smtp ===")
try {
    @smtp_result = notifications.smtp(
        "smtp.example.com",
        587,
        "user@example.com",
        "secret",
        "user@example.com",
        "recipient@example.com",
        "Hello from Corvo",
        "This message was sent by the Corvo notifications library."
    )
    sys.echo("SMTP sent: ${map.get(@smtp_result, "success")}")
} fallback {
    sys.echo("(skipped — no SMTP server configured)")
}

sys.echo("")
sys.echo("=== notifications.slack ===")
try {
    @slack_result = notifications.slack(
        "https://hooks.slack.com/services/YOUR/WEBHOOK/URL",
        "Hello from Corvo!"
    )
    sys.echo("Slack status: ${map.get(@slack_result, "status_code")}")
} fallback {
    sys.echo("(skipped — no Slack webhook configured)")
}

sys.echo("")
sys.echo("=== notifications.telegram ===")
try {
    @tg_result = notifications.telegram(
        "123456:ABC-YOUR-BOT-TOKEN",
        "-1001234567890",
        "Hello from Corvo!"
    )
    sys.echo("Telegram status: ${map.get(@tg_result, "status_code")}")
} fallback {
    sys.echo("(skipped — no Telegram bot configured)")
}

sys.echo("")
sys.echo("=== notifications.mattermost ===")
try {
    @mm_result = notifications.mattermost(
        "https://mattermost.example.com/hooks/YOUR_HOOK_ID",
        "Hello from Corvo!"
    )
    sys.echo("Mattermost status: ${map.get(@mm_result, "status_code")}")
} fallback {
    sys.echo("(skipped — no Mattermost webhook configured)")
}

sys.echo("")
sys.echo("=== notifications.gitter ===")
try {
    @gitter_result = notifications.gitter(
